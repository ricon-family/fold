#!/usr/bin/env bash
#MISE description="List agents in this home"
set -eo pipefail

NOTES_DIR="$MISE_CONFIG_ROOT/notes"

# Find agent identity files using farts frontmatter queries.
# Agent notes have `type: agent-identity` in their frontmatter.
for f in $(farts query 'type = identity' "$NOTES_DIR"/* 2>/dev/null); do
  [ ! -f "$f" ] && continue
  name=$(basename "$f" .md)
  # If the filename is a hex ID (obfuscated), use the title from frontmatter
  if [[ "$name" =~ ^[0-9a-f]+$ ]]; then
    title=$(farts get title "$f" 2>/dev/null)
    [ -n "$title" ] && name="$title"
  fi
  echo "$name"
done
