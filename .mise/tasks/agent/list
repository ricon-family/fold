#!/usr/bin/env bash
#MISE description="List agents in this home"
#USAGE flag "--ci" default=#false help="Only list agents with CI workflows enabled"
#USAGE flag "--json" default=#false help="Output JSON records with agent metadata"
set -euo pipefail

cd "$MISE_CONFIG_ROOT"

CI_ONLY="${usage_ci:-false}"
JSON_OUTPUT="${usage_json:-false}"

python3 - "$CI_ONLY" "$JSON_OUTPUT" <<'PY'
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path
from typing import Any

ci_only = sys.argv[1] == "true"
json_output = sys.argv[2] == "true"


def run_json(command: list[str]) -> Any:
    result = subprocess.run(
        command,
        check=True,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    return json.loads(result.stdout)


def parse_note(path: str) -> dict[str, Any]:
    parsed = run_json(["notes", "parse", path])
    frontmatter = parsed.get("frontmatter")
    if not isinstance(frontmatter, dict):
        return {}
    return frontmatter


def as_bool(value: Any) -> bool:
    if isinstance(value, bool):
        return value
    return str(value).strip().lower() == "true"


try:
    rows = run_json(["notes", "list", "--json", "--type", "agent"])
except subprocess.CalledProcessError as error:
    print("Error: failed to list agent identity files with notes.", file=sys.stderr)
    if error.stderr:
        print("notes stderr:", file=sys.stderr)
        for line in error.stderr.splitlines():
            print(f"  {line}", file=sys.stderr)
    raise SystemExit(1)

if not isinstance(rows, list):
    print("Error: notes list returned non-array JSON.", file=sys.stderr)
    raise SystemExit(1)

records: list[dict[str, Any]] = []
need_frontmatter = ci_only or json_output

for row in rows:
    if not isinstance(row, dict):
        continue

    path = str(row.get("path") or "")
    name = str(row.get("slug") or Path(path).stem).strip()
    if not name:
        continue

    frontmatter: dict[str, Any] = {}
    if need_frontmatter:
        try:
            frontmatter = parse_note(path)
        except subprocess.CalledProcessError as error:
            print(f"Error: failed to parse agent note: {path}", file=sys.stderr)
            if error.stderr:
                for line in error.stderr.splitlines():
                    print(f"  {line}", file=sys.stderr)
            raise SystemExit(1)

    ci = as_bool(frontmatter.get("ci", row.get("ci", ""))) if need_frontmatter else False
    if ci_only and not ci:
        continue

    if json_output:
        records.append(
            {
                "name": name,
                "ci": ci,
                "github_login": str(frontmatter.get("github_login") or "").strip(),
                "path": path,
            }
        )
    else:
        records.append({"name": name})

records.sort(key=lambda record: record["name"])

if json_output:
    print(json.dumps(records, indent=2, sort_keys=True))
else:
    for record in records:
        print(record["name"])

if not ci_only and not records:
    print("Error: agent:list found no agents in notes/.", file=sys.stderr)
    print("Are notes unlocked and readable?", file=sys.stderr)
    raise SystemExit(1)
PY
