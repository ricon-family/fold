#!/usr/bin/env bash
#MISE description="Output the identity content for an agent"
#USAGE arg "<agent>" help="Agent name"
set -eo pipefail

AGENT="$usage_agent"
IDENTITY_FILE="$MISE_CONFIG_ROOT/notes/$AGENT.md"

if [ ! -f "$IDENTITY_FILE" ]; then
  echo "Error: no identity file for agent '$AGENT' at $IDENTITY_FILE" >&2
  exit 1
fi

if file -b "$IDENTITY_FILE" 2>/dev/null | grep -q "data"; then
  echo "Error: $IDENTITY_FILE appears encrypted. Run: notes unlock" >&2
  exit 1
fi

cat "$IDENTITY_FILE"
