#!/usr/bin/env bash
#MISE description="Resolve the identity file path for an agent"
#USAGE arg "<agent>" help="Agent name"
set -eo pipefail

AGENT="$usage_agent"
IDENTITY_FILE="$MISE_PROJECT_ROOT/notes/$AGENT.md"

if [ ! -f "$IDENTITY_FILE" ]; then
  echo "Error: no identity file for agent '$AGENT' at $IDENTITY_FILE" >&2
  exit 1
fi

echo "$IDENTITY_FILE"

# Warn if file appears encrypted (non-blocking — path is still returned)
if file -b "$IDENTITY_FILE" 2>/dev/null | grep -q "data"; then
  echo "Warning: $IDENTITY_FILE appears encrypted. Run: notes encrypt:unlock" >&2
fi
