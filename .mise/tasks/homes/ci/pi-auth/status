#!/usr/bin/env bash
#MISE description="Show PI_AUTH_JSON source and home CI Actions secret presence"
#USAGE flag "--repo <repo>" var=#true default="" help="Home repo target (repeatable): OWNER/REPO:agent; default is all CI fold-agent homes"
#USAGE flag "--source <path>" default="" help="Path to pi auth.json (default: ~/.pi/agent/auth.json or $PI_CODING_AGENT_DIR/auth.json)"
#USAGE flag "--check" default=#false help="Exit nonzero when source is invalid or any target lacks PI_AUTH_JSON"
#USAGE example "mise run homes:ci:pi-auth:status" header="Check local PI auth source and PI_AUTH_JSON presence for all fold-agent homes"
#USAGE example "mise run homes:ci:pi-auth:status --repo c0da-ricon/home:c0da --check" header="Check one home and fail on missing auth"
set -euo pipefail

ROOT="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"
# shellcheck source=.mise/lib/homes/ci.sh
source "$ROOT/.mise/lib/homes/ci.sh"

REPO_TARGETS="${usage_repo:-}"
SOURCE="${usage_source:-${PI_CODING_AGENT_DIR:-$HOME/.pi/agent}/auth.json}"
CHECK="${usage_check:-false}"
TMP_DIR=$(mktemp -d)
TARGETS_FILE="$TMP_DIR/targets.tsv"
status=0

cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT

homes_ci_require_tools
homes_ci_targets_file "$REPO_TARGETS" "$TARGETS_FILE"

source_status="present"
source_detail="valid JSON object"
if [ ! -f "$SOURCE" ]; then
  source_status="missing"
  source_detail="source file not found"
  status=1
elif [ ! -s "$SOURCE" ]; then
  source_status="invalid"
  source_detail="source file is empty"
  status=1
elif ! "$HOMES_CI_JQ_BIN" -e 'type == "object" and length > 0' "$SOURCE" >/dev/null 2>&1; then
  source_status="invalid"
  source_detail="source is not a non-empty JSON object"
  status=1
fi

printf 'Source\tStatus\tDetail\n'
printf '%s\t%s\t%s\n\n' "$SOURCE" "$source_status" "$source_detail"
homes_ci_print_secret_status "$TARGETS_FILE" pi-auth "$TMP_DIR" || status=1

if [ "$CHECK" = "true" ]; then
  exit "$status"
fi
