#!/usr/bin/env bash
#MISE description="Sync required agent home CI Actions secrets"
#USAGE flag "--repo <repo>" var=#true default="" help="Home repo target (repeatable): OWNER/REPO:agent; default is all CI fold-agent homes"
#USAGE flag "-y --yes" default=#false help="Mutate GitHub Actions secrets; default is dry-run"
#USAGE example "mise run homes:ci:secrets:sync --repo c0da-ricon/home:c0da" header="Dry-run required CI secret sync for one home"
#USAGE example "mise run homes:ci:secrets:sync --repo c0da-ricon/home:c0da --yes" header="Sync required CI secrets for one home"
set -euo pipefail

ROOT="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"
# shellcheck source=.mise/lib/homes/ci.sh
source "$ROOT/.mise/lib/homes/ci.sh"

REPO_TARGETS="${usage_repo:-}"
YES="${usage_yes:-false}"
TMP_DIR=$(mktemp -d)
TARGETS_FILE="$TMP_DIR/targets.tsv"
status=0

cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT

homes_ci_require_tools
homes_ci_targets_file "$REPO_TARGETS" "$TARGETS_FILE"

if [ "$YES" = "true" ]; then
  printf 'Mode\tmutating\n'
  printf 'Effect\tsets required per-agent GitHub Actions secrets on target home repos\n'
else
  printf 'Mode\tdry-run\n'
  printf 'Effect\tno GitHub Actions secrets changed; pass --yes to sync\n'
fi
printf 'Scope\t%s\n' 'agent GitHub PAT, GPG private key, and email password only; run homes:ci:pi-auth:sync separately for PI_AUTH_JSON'
printf 'Rotation\t%s\n' 'no PATs are created, rotated, or revoked; existing secret-provider values are uploaded'
printf '\n'

homes_ci_sync_agent_secrets "$TARGETS_FILE" "$YES" "$TMP_DIR" || status=1
exit "$status"
