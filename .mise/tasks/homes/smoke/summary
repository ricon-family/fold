#!/usr/bin/env bash
#MISE description="Summarize homes campaign smoke results"
#USAGE flag "--work-dir <path>" default="" help="Campaign state directory (default: /tmp/<agent>.d/fold-homes-campaign/state)"
#USAGE flag "--state <path>" default="" help="Deprecated alias for --work-dir"
#USAGE example "mise run homes:smoke:summary" header="Summarize prepare smoke and prepared-state tables"
set -euo pipefail

ROOT="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"
# shellcheck source=.mise/lib/homes_campaign.sh
source "$ROOT/.mise/lib/homes_campaign.sh"

if [ -n "${usage_work_dir:-}" ] && [ -n "${usage_state:-}" ] && [ "${usage_work_dir}" != "${usage_state}" ]; then
  campaign_die "--work-dir and --state disagree"
fi
WORK_DIR_INPUT="${usage_work_dir:-${usage_state:-}}"
WORK_DIR=$(campaign_resolve_work_dir "$WORK_DIR_INPUT")
PREP="$WORK_DIR/agent-prepare-smoke.tsv"
POST="$WORK_DIR/prepared-state.tsv"
campaign_require_file "$PREP" "prepare smoke results"

printf 'Prepare smoke:\n'
column -t -s $'\t' "$PREP"

if [ -f "$POST" ]; then
  printf '\nPrepared state:\n'
  column -t -s $'\t' "$POST"
fi

fails=$(awk -F '\t' 'NR > 1 && $3 != "PASS" { count++ } END { print count + 0 }' "$PREP")
if [ "$fails" -ne 0 ]; then
  printf '\nFAILURES: %s\n' "$fails" >&2
  exit 1
fi
