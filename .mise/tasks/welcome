#!/usr/bin/env bash
#MISE description="Fold overview — residents, threads, chat, notes, repo status"
set -eo pipefail

FOLD_DIR="$MISE_CONFIG_ROOT"

# Colors
HEADING=212   # pink
SUBHEAD=81    # blue
DIM=240       # gray

# Section heading helper
section() {
  echo ""
  gum style --bold --foreground "$HEADING" "$1"
}

notes_repo_status() {
  local repo_dir="$1"
  enc_status="n/a"
  notes_status="n/a"

  if [ ! -d "$repo_dir/notes" ]; then
    notes_status="no notes dir"
    return
  fi

  if [ ! -d "$repo_dir/.git/git-crypt" ]; then
    enc_status="⚠ not set up → notes setup"
  elif ! command -v git-crypt &>/dev/null; then
    enc_status="⚠ git-crypt not installed"
  elif git -C "$repo_dir" crypt status -e &>/dev/null; then
    enc_status="✓ unlocked"
  else
    enc_status="⚠ locked → notes unlock"
  fi

  if [ ! -f "$repo_dir/notes/.manifest" ]; then
    notes_status="no manifest"
    return
  fi

  local first_name
  first_name=$(awk -F'\t' 'NF >= 2 { print $2; exit }' "$repo_dir/notes/.manifest")
  if [ -z "$first_name" ]; then
    notes_status="manifest empty"
    return
  fi

  if [ ! -f "$repo_dir/notes/$first_name" ]; then
    notes_status="⚠ obfuscated → notes unlock"
    return
  fi

  if ! command -v notes &>/dev/null; then
    notes_status="⚠ notes CLI missing"
    return
  fi

  local changes_output change_count
  if ! changes_output=$(cd "$repo_dir" && notes changes --summary 2>&1); then
    notes_status="⚠ check failed → notes changes --summary"
    return
  fi

  if printf '%s\n' "$changes_output" | grep -q '^No changes\.$'; then
    notes_status="✓ readable; no note edits"
    return
  fi

  change_count=$(printf '%s\n' "$changes_output" | awk '/ change\(s\):/ { print $1; exit }')
  if [ -n "$change_count" ]; then
    notes_status="⚠ readable; ${change_count} note change(s) → notes changes --summary"
  else
    notes_status="⚠ readable; changes possible → notes changes --summary"
  fi
}

# ━━━ Header ━━━
echo ""
gum style --bold --foreground "$HEADING" --border double --border-foreground "$DIM" \
  --padding "0 2" "🏠 The Fold"
gum style --faint "$(date '+%A, %B %-d, %Y · %-I:%M %p')"

# ━━━ Residents ━━━
section "Residents"
if command -v fold &>/dev/null; then
  agents=$(cd "$FOLD_DIR" && mise run -q agent:list 2>/dev/null || true)
  if [ -n "$agents" ]; then
    agent_rows=""
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      last_activity=$(cd "$FOLD_DIR" && git log -1 --format='%ar' --author="$name" 2>/dev/null || echo "unknown")
      agent_rows+="${name},${last_activity}"$'\n'
    done <<< "$agents"
    printf "Agent,Last Active\n%s" "$agent_rows" \
      | gum table --print --separator "," --border rounded \
          --border.foreground "$DIM" --header.foreground "$SUBHEAD"
  fi
fi

# ━━━ HUMAN.md ━━━
HUMAN_FILE=$(cd "$FOLD_DIR" && mise run -q human 2>/dev/null)
if [ -n "$HUMAN_FILE" ] && [ -f "$HUMAN_FILE" ]; then
  thread_summary=$(threads status --file "$HUMAN_FILE" 2>/dev/null || echo "")
  section "📝 HUMAN.md  ($thread_summary)"
  threads list --file "$HUMAN_FILE" 2>/dev/null || true
else
  section "📝 HUMAN.md"
  gum style --faint "(HUMAN_MD not set — see: mise run human)"
fi

# ━━━ Chat ━━━
section "💬 Chat"
if command -v chat &>/dev/null; then
  chat list 2>/dev/null || gum style --faint "(no chat channels)"

  # Quick reference — detect agent name from env (set by shimmer)
  _agent="${AGENT_NAME:-${GIT_AUTHOR_NAME:-}}"
  if [ -n "$_agent" ]; then
    _agent_lower=$(echo "$_agent" | tr '[:upper:]' '[:lower:]')
    echo ""
    (
      printf 'Action\tCommand\n'
      printf 'Read new messages (default channel)\tchat read\n'
      printf 'Read a specific channel\tchat read <channel>\n'
      printf 'Read as %s identity/cursor\tchat read --as %s <channel>\n' "$_agent_lower" "$_agent_lower"
      printf 'Send a message\tchat send --as %s <msg>\n' "$_agent_lower"
      printf 'Wait for any message from others\tchat wait --as %s <channel>\n' "$_agent_lower"
      printf 'Peek without marking read\tchat read --peek <channel>\n'
      printf 'Send to specific channel\tchat send --as %s --chat <channel> <msg>\n' "$_agent_lower"
      printf 'List all channels\tchat list\n'
    ) | gum table --print --separator "	" --border rounded \
          --border.foreground "$DIM" --header.foreground "$DIM"
  fi
else
  gum style --faint "(chat not installed — run: shiv install chat)"
fi

# ━━━ Notes ━━━
# Disabled: notes list is too slow (~18s due to per-file farts calls). See den#10.
# NOTES_DIR="$FOLD_DIR/notes"
# if [ -d "$NOTES_DIR" ]; then
#   note_count=$(cd "$FOLD_DIR" && notes list -- --json 2>/dev/null | python3 -c "import sys, json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "?")
#   section "📓 Notes  (${note_count} notes)"
#   (cd "$FOLD_DIR" && notes list -- --recent 5 2>/dev/null || true)
# fi

# ━━━ Modules ━━━
# Hygiene checks for nested module clones:
#   - Pin freshness: warn when clone is behind origin/<default-branch>; user
#     decides whether to `modules update <name>` to bump.
#   - Notes hooks: ensure pre-commit hook is installed in notes-tracked
#     clones, since `modules init` does not install them and missing hooks
#     risk leaking plaintext on commit.
if [ -d "$FOLD_DIR/modules" ]; then
  section "🧩 Modules"
  module_rows=""
  for mod_path in "$FOLD_DIR/modules"/*/; do
    [ -d "$mod_path/.git" ] || continue
    name=$(basename "$mod_path")

    # Pin freshness
    git -C "$mod_path" fetch -q 2>/dev/null || true
    default_branch=$(git -C "$mod_path" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
    default_branch=${default_branch:-main}
    behind=$(git -C "$mod_path" rev-list --count "HEAD..origin/${default_branch}" 2>/dev/null || echo 0)
    if [ "${behind:-0}" -gt 0 ]; then
      pin_status="⚠ ${behind} behind origin/${default_branch} → modules update ${name}"
    else
      pin_status="✓ at tip of ${default_branch}"
    fi

    # Notes hooks
    if [ ! -f "$mod_path/notes/.manifest" ]; then
      hook_status="n/a"
    elif [ -f "$mod_path/.git/hooks/pre-commit" ]; then
      hook_status="✓ installed"
    else
      (cd "$mod_path" && notes install-hooks >/dev/null 2>&1) || true
      hook_status="⚠ installed (was missing)"
    fi

    module_rows+="${name},${pin_status},${hook_status}"$'\n'
  done
  if [ -n "$module_rows" ]; then
    printf "Module,Pin,Hooks\n%s" "$module_rows" \
      | gum table --print --separator "," --border rounded \
          --border.foreground "$DIM" --header.foreground "$SUBHEAD"
  else
    gum style --faint "(no nested modules initialized — run: modules init)"
  fi
fi

# ━━━ Repo & Status ━━━
section "📦 Repo"
cd "$FOLD_DIR"
branch=$(git branch --show-current 2>/dev/null)
dirty=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')

if [ "$dirty" -gt 0 ]; then
  branch_status="$branch ($dirty uncommitted)"
else
  branch_status="$branch (clean)"
fi

tracking=$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || echo "")
sync_status=""
if [ -n "$tracking" ]; then
  ahead=$(git rev-list "$tracking..HEAD" --count 2>/dev/null || echo "0")
  behind=$(git rev-list "HEAD..$tracking" --count 2>/dev/null || echo "0")
  [ "$ahead" -gt 0 ] && sync_status+="↑${ahead} ahead "
  [ "$behind" -gt 0 ] && sync_status+="↓${behind} behind "
  [ -z "$sync_status" ] && sync_status="up to date"
fi

repo_rows="Branch,${branch_status}"$'\n'
[ -n "$sync_status" ] && repo_rows+="Remote,${sync_status}"$'\n'

# Open issues
issue_count=$(GH_HOST=github.com gh issue list --repo ricon-family/fold --state open --json number --jq 'length' 2>/dev/null || echo "?")
repo_rows+="Issues,${issue_count} open"$'\n'

notes_repo_status "$FOLD_DIR"
repo_rows+="Encryption,${enc_status}"$'\n'
repo_rows+="Notes,${notes_status}"

printf "Property,Status\n%s\n" "$repo_rows" \
  | gum table --print --separator "," --border rounded \
      --border.foreground "$DIM" --header.foreground "$SUBHEAD"

echo ""
