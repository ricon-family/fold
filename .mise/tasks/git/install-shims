#!/usr/bin/env bash
#MISE description="Install Git-style preflight shims that resolve the active agent's fold clone"
#USAGE flag "--bin-dir <dir>" default="" help="Directory for shims (default: ~/.local/bin)"
#USAGE flag "--force" default=#false help="Overwrite existing commands even if they were not generated by fold"
set -euo pipefail

BIN_DIR="${usage_bin_dir:-}"
FORCE="${usage_force:-false}"
MARKER="Generated by fold git:install-shims"

if [ -z "$BIN_DIR" ]; then
  BIN_DIR="$HOME/.local/bin"
fi
case "$BIN_DIR" in
  /*) ;;
  *) BIN_DIR="$PWD/$BIN_DIR" ;;
esac

mkdir -p "$BIN_DIR"

install_one() {
  local command_name="$1"
  local task_name="$2"
  local target="$BIN_DIR/$command_name"

  if [ -e "$target" ] && ! grep -q "$MARKER" "$target" 2>/dev/null && [ "$FORCE" != "true" ]; then
    echo "Error: $target exists and was not generated by fold. Use --force or choose --bin-dir." >&2
    return 1
  fi

  cat > "$target" <<EOF
#!/usr/bin/env bash
# $MARKER
set -euo pipefail

active_agent() {
  local candidate local_part

  candidate="\${AGENT_NAME:-}"
  if [ -n "\$candidate" ] && [ -d "\$HOME/agents/\$candidate/home/modules/fold" ]; then
    printf '%s\n' "\$candidate"
    return 0
  fi

  candidate="\${GIT_AUTHOR_NAME:-}"
  if [ -n "\$candidate" ] && [ -d "\$HOME/agents/\$candidate/home/modules/fold" ]; then
    printf '%s\n' "\$candidate"
    return 0
  fi

  if [ -n "\${GIT_AUTHOR_EMAIL:-}" ]; then
    local_part=\${GIT_AUTHOR_EMAIL%@*}
    if [ -n "\$local_part" ] && [ -d "\$HOME/agents/\$local_part/home/modules/fold" ]; then
      printf '%s\n' "\$local_part"
      return 0
    fi
  fi

  return 1
}

if [ -n "\${FOLD_GIT_FOLD_DIR:-}" ]; then
  FOLD_DIR="\$FOLD_GIT_FOLD_DIR"
elif agent=\$(active_agent); then
  FOLD_DIR="\$HOME/agents/\$agent/home/modules/fold"
else
  echo "Error: cannot determine active agent fold clone." >&2
  echo 'Run eval "\$(shimmer as <agent>)" first, or set FOLD_GIT_FOLD_DIR=/path/to/fold.' >&2
  exit 1
fi

if [ ! -d "\$FOLD_DIR/.git" ]; then
  echo "Error: fold clone not found at \$FOLD_DIR" >&2
  echo "Run modules init in the active agent home, or set FOLD_GIT_FOLD_DIR=/path/to/fold." >&2
  exit 1
fi

caller_pwd=\$(pwd -P)
exec env \
  FOLD_CALLER_PWD="\$caller_pwd" \
  FOLD_GIT_SHIM=1 \
  FOLD_GIT_SHIM_COMMAND="git ${command_name#git-}" \
  FOLD_GIT_SHIM_EXECUTABLE="$command_name" \
  mise run -q -C "\$FOLD_DIR" $task_name "\$@"
EOF
  chmod +x "$target"
  printf '  ✓ %s -> active agent fold %s\n' "$target" "$task_name"
}

install_one git-pre-commit git:pre-commit
install_one git-pre-push git:pre-push
install_one git-pre-publish git:pre-publish

case ":$PATH:" in
  *":$BIN_DIR:"*) ;;
  *) echo "  ⚠ $BIN_DIR is not on PATH; add it before using git pre-push / git pre-publish" ;;
esac

echo "Done. Try: git pre-push"
