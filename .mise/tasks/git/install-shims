#!/usr/bin/env bash
#MISE description="Install Git-style preflight shims that resolve fold from AGENT_HOME"
#USAGE flag "--bin-dir <dir>" default="" help="Directory for shims (default: ~/.local/bin)"
#USAGE flag "--force" default=#false help="Overwrite existing commands even if they were not generated by fold"
set -euo pipefail

BIN_DIR="${usage_bin_dir:-}"
FORCE="${usage_force:-false}"
MARKER="Generated by fold git:install-shims"

if [ -z "$BIN_DIR" ]; then
  BIN_DIR="$HOME/.local/bin"
fi
case "$BIN_DIR" in
  /*) ;;
  *) BIN_DIR="$PWD/$BIN_DIR" ;;
esac

mkdir -p "$BIN_DIR"

install_one() {
  local command_name="$1"
  local task_name="$2"
  local target="$BIN_DIR/$command_name"

  if [ -e "$target" ] && ! grep -q "$MARKER" "$target" 2>/dev/null && [ "$FORCE" != "true" ]; then
    echo "Error: $target exists and was not generated by fold. Use --force or choose --bin-dir." >&2
    return 1
  fi

  cat > "$target" <<EOF
#!/usr/bin/env bash
# $MARKER
set -euo pipefail

if [ -z "\${AGENT_HOME:-}" ]; then
  echo "Error: AGENT_HOME is not set; cannot locate the active fold module." >&2
  echo 'Run from a prepared agent home or desk with AGENT_HOME exported.' >&2
  exit 1
fi

case "\$AGENT_HOME" in
  /*) ;;
  *)
    echo "Error: AGENT_HOME must be an absolute path: \$AGENT_HOME" >&2
    exit 1
    ;;
esac

FOLD_DIR="\$AGENT_HOME/modules/fold"

if ! git -C "\$FOLD_DIR" rev-parse --show-toplevel >/dev/null 2>&1; then
  echo "Error: fold clone not found at \$FOLD_DIR" >&2
  echo 'Expected a prepared fold module at $AGENT_HOME/modules/fold.' >&2
  exit 1
fi

caller_pwd=\$(pwd -P)
exec env \
  FOLD_CALLER_PWD="\$caller_pwd" \
  FOLD_GIT_SHIM=1 \
  FOLD_GIT_SHIM_COMMAND="git ${command_name#git-}" \
  FOLD_GIT_SHIM_EXECUTABLE="$command_name" \
  mise run -q -C "\$FOLD_DIR" $task_name "\$@"
EOF
  chmod +x "$target"
  printf '  ✓ %s -> AGENT_HOME fold %s\n' "$target" "$task_name"
}

install_one git-pre-commit git:pre-commit
install_one git-pre-push git:pre-push
install_one git-pre-publish git:pre-publish

case ":$PATH:" in
  *":$BIN_DIR:"*) ;;
  *) echo "  ⚠ $BIN_DIR is not on PATH; add it before using git pre-push / git pre-publish" ;;
esac

echo "Done. Try: git pre-push"
