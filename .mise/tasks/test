#!/usr/bin/env bash
#MISE description="Run fold tests"
#USAGE arg "[args]" var=#true default="" help="Test suites, bats args, or 'codebase'"
#USAGE example "mise run test" header="Run all BATS tests and codebase lints"
#USAGE example "mise run test github-2fa-enroll" header="Run one BATS suite by name"
#USAGE example "mise run test codebase" header="Run configured codebase lints"
#USAGE example "mise run test --filter stores" header="Filter BATS tests"
set -euo pipefail

ROOT="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"
TEST_DIR="$ROOT/test"
CODEBASE_BIN="${CODEBASE_BIN:-codebase}"

args=()
if [ -n "${usage_args:-}" ]; then
  while IFS= read -r arg; do
    [ -z "$arg" ] && continue
    args+=("$arg")
  done < <(printf '%s' "${usage_args}" | xargs printf '%s\n')
fi

run_bats=false
run_codebase=false
bats_args=()
has_bats_target=false

if [ "${#args[@]}" -eq 0 ]; then
  run_bats=true
  run_codebase=true
else
  for arg in ${args[@]+"${args[@]}"}; do
    if [ "$arg" = "codebase" ]; then
      run_codebase=true
      continue
    fi

    run_bats=true
    if [[ "$arg" != -* && "$arg" != *.bats && -f "$TEST_DIR/$arg.bats" ]]; then
      bats_args+=("$TEST_DIR/$arg.bats")
      has_bats_target=true
    else
      if [[ "$arg" == *.bats || -d "$arg" ]]; then
        has_bats_target=true
      fi
      bats_args+=("$arg")
    fi
  done
fi

if [ "$run_bats" = "true" ]; then
  if [ "$has_bats_target" = "false" ]; then
    bats_args+=("$TEST_DIR/")
  fi
  bats "${bats_args[@]}"
fi

if [ "$run_codebase" = "true" ]; then
  lint_line=$(grep -E '^[[:space:]]*lint[[:space:]]*=' "$ROOT/mise.toml" | head -1 || true)
  if [ -z "$lint_line" ]; then
    echo "ERROR: no [_.codebase] lint list found in mise.toml" >&2
    exit 1
  fi

  lint_names=$(printf '%s\n' "$lint_line" \
    | sed -E 's/^[^=]*=//; s/[][]//g; s/"//g; s/[[:space:]]//g' \
    | tr ',' '\n' \
    | sed '/^$/d')

  if [ -z "$lint_names" ]; then
    echo "ERROR: codebase lint list is empty" >&2
    exit 1
  fi

  while IFS= read -r lint_name; do
    (cd "$ROOT" && mise exec -- "$CODEBASE_BIN" "lint:$lint_name" "$ROOT")
  done <<EOF
$lint_names
EOF
fi
