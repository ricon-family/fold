#!/usr/bin/env bash
#MISE description="Sync stored agent secrets to fold GitHub Actions with an operator token"
#USAGE flag "--dry-run" default=#false help="Show what would be synced without writing GitHub secrets"
#USAGE flag "--with-api-key" default=#false help="Also sync the shared ANTHROPIC_API_KEY secret"
#USAGE flag "--operator <agent>" default="" help="Agent whose stored GitHub PAT has fold Actions-secret permission"
#USAGE arg "[agents]" var=#true default="" help="Agent names to sync (default: CI-enabled fold agents)"
set -euo pipefail

ROOT="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"
DRY_RUN="${usage_dry_run:-false}"
WITH_API_KEY="${usage_with_api_key:-false}"
OPERATOR="${usage_operator:-}"
AGENTS_ARG="${usage_agents:-}"

require_tool() {
  local tool="$1"
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "ERROR: required tool not found: $tool" >&2
    exit 1
  fi
}

validate_agent() {
  local agent="$1"
  if [[ ! "$agent" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "ERROR: invalid agent name: $agent" >&2
    exit 1
  fi
}

parse_explicit_agents() {
  printf '%s' "$AGENTS_ARG" | xargs printf '%s\n' | while IFS= read -r agent; do
    [ -n "$agent" ] || continue
    validate_agent "$agent"
    printf '%s\n' "$agent"
  done
}

list_default_agents() {
  (cd "$ROOT" && mise run -q agent:list --ci)
}

run_with_operator() {
  if [ -n "${OPERATOR_TOKEN:-}" ]; then
    GH_TOKEN="$OPERATOR_TOKEN" "$@"
  else
    "$@"
  fi
}

resolve_operator_token() {
  if [ -n "$OPERATOR" ]; then
    validate_agent "$OPERATOR"
    if ! OPERATOR_TOKEN=$(secrets get "$OPERATOR/github-pat" 2>/dev/null); then
      echo "ERROR: could not read $OPERATOR/github-pat for CI sync operator" >&2
      exit 1
    fi
    if [ -z "$OPERATOR_TOKEN" ]; then
      echo "ERROR: $OPERATOR/github-pat is empty" >&2
      exit 1
    fi
    export OPERATOR_TOKEN
    return 0
  fi

  if [ -n "${GH_TOKEN:-}" ]; then
    OPERATOR_TOKEN="$GH_TOKEN"
    export OPERATOR_TOKEN
    return 0
  fi

  if [ -n "${GITHUB_TOKEN:-}" ]; then
    OPERATOR_TOKEN="$GITHUB_TOKEN"
    export OPERATOR_TOKEN
    return 0
  fi

  if [ -n "${GIT_AUTHOR_NAME:-}" ] && OPERATOR_TOKEN=$(secrets get "$GIT_AUTHOR_NAME/github-pat" 2>/dev/null); then
    if [ -n "$OPERATOR_TOKEN" ]; then
      export OPERATOR_TOKEN
      return 0
    fi
  fi

  unset OPERATOR_TOKEN
}

verify_operator_access() {
  local err
  err=$(mktemp)
  if run_with_operator gh api repos/ricon-family/fold/actions/secrets/public-key --jq .key >/dev/null 2>"$err"; then
    rm -f "$err"
    return 0
  fi

  echo "ERROR: operator GitHub auth cannot manage ricon-family/fold Actions secrets" >&2
  sed 's/^/  /' "$err" >&2
  rm -f "$err"
  exit 1
}

sync_one() {
  local agent="$1"
  validate_agent "$agent"

  args=(agent:sync-secrets "$agent")
  if [ "$DRY_RUN" = "true" ]; then
    args+=(--dry-run)
  fi
  if [ "$WITH_API_KEY" = "true" ]; then
    args+=(--with-api-key)
  fi

  (cd "$ROOT" && run_with_operator shimmer "${args[@]}")
}

require_tool secrets
require_tool gh
require_tool shimmer
require_tool xargs

TMP_AGENTS=$(mktemp)
trap 'rm -f "$TMP_AGENTS"' EXIT

if [ -n "$AGENTS_ARG" ]; then
  parse_explicit_agents > "$TMP_AGENTS"
  if ! grep -q '[^[:space:]]' "$TMP_AGENTS"; then
    list_default_agents > "$TMP_AGENTS"
  fi
else
  list_default_agents > "$TMP_AGENTS"
fi

if ! grep -q '[^[:space:]]' "$TMP_AGENTS"; then
  echo "ERROR: no agents found" >&2
  exit 1
fi

sort -u "$TMP_AGENTS" -o "$TMP_AGENTS"

resolve_operator_token
verify_operator_access

if [ -n "$OPERATOR" ]; then
  echo "Using $OPERATOR/github-pat as fold CI sync operator."
elif [ -n "${OPERATOR_TOKEN:-}" ]; then
  echo "Using provided GitHub token as fold CI sync operator."
else
  echo "Using gh's ambient authenticated user as fold CI sync operator."
fi

echo ""
while IFS= read -r agent; do
  [ -n "$agent" ] || continue
  sync_one "$agent"
done < "$TMP_AGENTS"
