#!/usr/bin/env bash
#MISE description="Rotate agent GitHub classic PATs, store them, and sync the fold PAT CI secret"
#USAGE flag "-y --yes" default=#false help="Actually rotate tokens without prompting"
#USAGE flag "--dry-run" default=#false help="Check prerequisites without rotating, storing, or syncing"
#USAGE flag "--operator <agent>" default="" help="Agent whose stored GitHub PAT has fold Actions-secret permission"
#USAGE flag "--no-sync-ci" default=#false help="Rotate/store only; do not sync the fold PAT CI secret"
#USAGE arg "[agents]" var=#true default="" help="Agent names to rotate (default: CI-enabled fold agents)"
set -euo pipefail

ROOT="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"
YES="${usage_yes:-false}"
DRY_RUN="${usage_dry_run:-false}"
OPERATOR="${usage_operator:-${GIT_AUTHOR_NAME:-}}"
NO_SYNC_CI="${usage_no_sync_ci:-false}"
AGENTS_ARG="${usage_agents:-}"
SECRETS_BIN="${SECRETS_BIN:-secrets}"
WEBSITES_BIN="${WEBSITES_BIN:-websites}"
SHIMMER_BIN="${SHIMMER_BIN:-shimmer}"
GH_BIN="${GH_BIN:-gh}"
AWK_BIN="${AWK_BIN:-awk}"
XARGS_BIN="${XARGS_BIN:-xargs}"

require_tool() {
  local tool="$1"
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "ERROR: required tool not found: $tool" >&2
    exit 1
  fi
}

redact() {
  sed -E \
    -e 's/gh[pousr]_[A-Za-z0-9_]+/[REDACTED_GITHUB_TOKEN]/g' \
    -e 's/github_pat_[A-Za-z0-9_]+/[REDACTED_GITHUB_TOKEN]/g' \
    -e 's/[A-Z2-7]{16,}/[REDACTED_BASE32]/g' \
    -e 's/[a-z0-9]{5}-[a-z0-9]{5}/[REDACTED_RECOVERY_CODE]/gi' \
    -e 's/(Password: ).*/\1[REDACTED]/g' \
    -e 's/(GITHUB_PASSWORD=)[^[:space:]]+/\1[REDACTED]/g' \
    -e 's/(GITHUB_TOTP_CODE=)[^[:space:]]+/\1[REDACTED_TOTP_CODE]/g' \
    -e 's/(GITHUB_TOTP_COMMAND=).*/\1[REDACTED_TOTP_COMMAND]/g' \
    -e 's#([^[:space:]]*/)?secrets[[:space:]]+totp[[:space:]]+[A-Za-z0-9._-]+/github-totp#[REDACTED_TOTP_COMMAND]#g' \
    -e 's/([Tt][Oo][Tt][Pp][^0-9]{0,32})[0-9]{6}/\1[REDACTED_TOTP_CODE]/g' \
    -e 's/(^|[^0-9])[0-9]{6}([^0-9]|$)/\1[REDACTED_TOTP_CODE]\2/g'
}

redact_literal() {
  local literal="$1"
  local replacement="$2"
  awk -v literal="$literal" -v replacement="$replacement" '
    literal == "" { print; next }
    {
      out = ""
      rest = $0
      while ((idx = index(rest, literal)) > 0) {
        out = out substr(rest, 1, idx - 1) replacement
        rest = substr(rest, idx + length(literal))
      }
      print out rest
    }
  '
}

redact_sensitive() {
  local password="$1"
  redact | redact_literal "$password" "[REDACTED_PASSWORD]"
}

validate_agent() {
  local agent="$1"
  if [[ ! "$agent" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "ERROR: invalid agent name: $agent" >&2
    exit 1
  fi
}

parse_explicit_agents() {
  printf '%s' "$AGENTS_ARG" | "$XARGS_BIN" printf '%s\n' | while IFS= read -r agent; do
    [ -n "$agent" ] || continue
    validate_agent "$agent"
    printf '%s\n' "$agent"
  done
}

list_default_agents() {
  (cd "$ROOT" && mise run -q agent:list --ci)
}

load_operator_token() {
  if [ "$NO_SYNC_CI" = "true" ]; then
    return 0
  fi

  if [ -z "$OPERATOR" ]; then
    echo "ERROR: CI sync requires --operator <agent> or GIT_AUTHOR_NAME identity" >&2
    echo "       Use --no-sync-ci to rotate/store without syncing the fold PAT CI secret." >&2
    exit 1
  fi
  validate_agent "$OPERATOR"

  if ! OPERATOR_TOKEN=$("$SECRETS_BIN" get "$OPERATOR/github-pat" 2>/dev/null); then
    echo "ERROR: could not read $OPERATOR/github-pat for CI sync operator" >&2
    exit 1
  fi
  if [ -z "$OPERATOR_TOKEN" ]; then
    echo "ERROR: $OPERATOR/github-pat is empty" >&2
    exit 1
  fi
  export OPERATOR_TOKEN
}

verify_operator_access() {
  if [ "$NO_SYNC_CI" = "true" ]; then
    return 0
  fi

  local err
  err=$(mktemp)
  if GH_TOKEN="$OPERATOR_TOKEN" "$GH_BIN" api repos/ricon-family/fold/actions/secrets/public-key --jq .key >/dev/null 2>"$err"; then
    rm -f "$err"
    return 0
  fi

  echo "ERROR: $OPERATOR/github-pat cannot manage ricon-family/fold Actions secrets" >&2
  sed 's/^/  /' "$err" >&2
  rm -f "$err"
  exit 1
}

sync_ci() {
  local agent="$1"
  if [ "$NO_SYNC_CI" = "true" ]; then
    echo "  - skipped CI sync (--no-sync-ci)"
    return 0
  fi

  (cd "$ROOT" && GH_TOKEN="$OPERATOR_TOKEN" mise run github:ci:secrets:sync --repo "ricon-family/fold:$agent" --pat --yes) >/dev/null
  echo "  ✓ synced fold GitHub PAT CI secret"
}

run_websites_rotate() {
  local agent="$1"
  local username="$2"
  local password="$3"
  local stdout="$4"
  local stderr="$5"
  local totp_command=""

  if "$SECRETS_BIN" get "$agent/github-totp" >/dev/null 2>&1; then
    printf -v totp_command '%q totp %q' "$SECRETS_BIN" "$agent/github-totp"
    GITHUB_USERNAME="$username" GITHUB_PASSWORD="$password" GITHUB_TOTP_COMMAND="$totp_command" \
      "$WEBSITES_BIN" github:token:rotate "$agent" --login-id "$agent" >"$stdout" 2>"$stderr"
  else
    GITHUB_USERNAME="$username" GITHUB_PASSWORD="$password" \
      "$WEBSITES_BIN" github:token:rotate "$agent" --login-id "$agent" >"$stdout" 2>"$stderr"
  fi
}

require_tool "$SECRETS_BIN"
require_tool "$WEBSITES_BIN"
require_tool "$SHIMMER_BIN"
require_tool "$GH_BIN"
require_tool "$AWK_BIN"
require_tool "$XARGS_BIN"

TMP_AGENTS=$(mktemp)
TMP_ROOT=$(mktemp -d)
chmod 700 "$TMP_ROOT"
trap 'rm -rf "$TMP_ROOT" "$TMP_AGENTS"' EXIT

if [ -n "$AGENTS_ARG" ]; then
  parse_explicit_agents > "$TMP_AGENTS"
  if ! grep -q '[^[:space:]]' "$TMP_AGENTS"; then
    list_default_agents > "$TMP_AGENTS"
  fi
else
  list_default_agents > "$TMP_AGENTS"
fi

if ! grep -q '[^[:space:]]' "$TMP_AGENTS"; then
  echo "ERROR: no agents found" >&2
  exit 1
fi

sort -u "$TMP_AGENTS" -o "$TMP_AGENTS"

load_operator_token
verify_operator_access

printf 'GitHub token rotation for fold agents\n\n'
printf 'Agents:\n'
while IFS= read -r agent; do
  [ -n "$agent" ] || continue
  validate_agent "$agent"
  printf '  - %s\n' "$agent"
done < "$TMP_AGENTS"
printf '\n'

if [ "$NO_SYNC_CI" != "true" ]; then
  printf 'CI sync operator: %s/github-pat\n\n' "$OPERATOR"
fi

printf 'Consent reminder: only rotate another agent credential with that agent or Or approving. See fold notes/credential-rotation-consent.md.\n\n'

if [ "$DRY_RUN" = "true" ]; then
  printf 'Dry run: checking required credentials only; no browser automation, storage, or CI sync.\n\n'
elif [ "$YES" != "true" ]; then
  echo "ERROR: rotation is destructive; rerun with --yes after confirming consent, or --dry-run to inspect." >&2
  exit 1
fi

while IFS= read -r agent; do
  [ -n "$agent" ] || continue
  validate_agent "$agent"
  printf '== %s ==\n' "$agent"

  username=$("$SECRETS_BIN" get "$agent/github-username" 2>/dev/null || true)
  password=$("$SECRETS_BIN" get "$agent/github-password" 2>/dev/null || true)
  if [ -z "$username" ] || [ -z "$password" ]; then
    printf '  ✗ missing github username/password secret\n'
    exit 1
  fi

  if [ "$DRY_RUN" = "true" ]; then
    if "$SECRETS_BIN" get "$agent/github-pat" >/dev/null 2>&1; then
      printf '  ✓ credentials present; current PAT present\n\n'
    else
      printf '  ⚠ credentials present; current PAT missing\n\n'
    fi
    unset username password
    continue
  fi

  agent_tmp="$TMP_ROOT/$agent"
  mkdir -p "$agent_tmp"
  stdout="$agent_tmp/stdout"
  stderr="$agent_tmp/stderr"

  if ! run_websites_rotate "$agent" "$username" "$password" "$stdout" "$stderr"; then
    printf '  ✗ rotation failed\n'
    printf '  sanitized diagnostics:\n'
    redact_sensitive "$password" <"$stderr" | sed 's/^/    /' | tail -80
    exit 1
  fi

  new_token=$("$AWK_BIN" '/^(ghp_|github_pat_)/ { value=$0 } END { print value }' "$stdout")
  if [ -z "$new_token" ]; then
    printf '  ✗ rotation produced no token on stdout\n'
    printf '  sanitized diagnostics:\n'
    redact_sensitive "$password" <"$stderr" | sed 's/^/    /' | tail -80
    exit 1
  fi
  printf '  ✓ rotated\n'

  "$SHIMMER_BIN" github:token:store "$agent" "$new_token" >/dev/null
  printf '  ✓ stored\n'

  if [ "$agent" = "$OPERATOR" ]; then
    OPERATOR_TOKEN="$new_token"
    export OPERATOR_TOKEN
  fi

  sync_ci "$agent"

  stored_token=$("$SECRETS_BIN" get "$agent/github-pat")
  login=$(GH_TOKEN="$stored_token" "$GH_BIN" api /user --jq .login 2>/dev/null || true)
  if [ -z "$login" ]; then
    printf '  ✗ verification failed\n'
    exit 1
  fi
  printf '  ✓ verified as %s\n\n' "$login"

  unset username password new_token stored_token login
  rm -rf "$agent_tmp"
done < "$TMP_AGENTS"

if [ "$DRY_RUN" = "true" ]; then
  printf 'Dry run complete. No tokens were rotated.\n'
else
  printf 'Rotation complete. Selected PATs were rotated, stored, synced when requested, and verified.\n'
fi
