#!/usr/bin/env bash
#MISE description="Show required agent CI Actions secret presence"
#USAGE flag "--repo <repo>" var=#true default="" help="CI repo target (repeatable): OWNER/REPO:agent; default is all CI fold-agent homes"
#USAGE flag "--check" default=#false help="Exit nonzero when any required secret is missing or cannot be checked"
#USAGE example "mise run github:ci:secrets:status" header="Check required CI secrets for all fold-agent homes"
#USAGE example "mise run github:ci:secrets:status --repo c0da-ricon/home:c0da --check" header="Check one home and fail when any required secret is absent"
set -euo pipefail

ROOT="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"
# shellcheck source=.mise/lib/github/ci.sh
source "$ROOT/.mise/lib/github/ci.sh"

REPO_TARGETS="${usage_repo:-}"
CHECK="${usage_check:-false}"
TMP_DIR=$(mktemp -d)
TARGETS_FILE="$TMP_DIR/targets.tsv"
status=0

cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT

github_ci_require_tools
github_ci_targets_file "$REPO_TARGETS" "$TARGETS_FILE"
github_ci_print_secret_status "$TARGETS_FILE" agent-home "$TMP_DIR" || status=1

if [ "$CHECK" = "true" ]; then
  exit "$status"
fi
