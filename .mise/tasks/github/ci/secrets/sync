#!/usr/bin/env bash
#MISE description="Sync selected agent CI Actions secrets"
#USAGE flag "--repo <repo>" var=#true default="" help="CI repo target (repeatable): OWNER/REPO:agent; default is all CI fold-agent homes"
#USAGE flag "--pat" default=#false help="Sync only each agent's GitHub PAT Actions secret"
#USAGE flag "-y --yes" default=#false help="Mutate GitHub Actions secrets; default is dry-run"
#USAGE example "mise run github:ci:secrets:sync --repo c0da-ricon/home:c0da" header="Dry-run required CI secret sync for one home"
#USAGE example "mise run github:ci:secrets:sync --repo c0da-ricon/home:c0da --yes" header="Sync required CI secrets for one home"
#USAGE example "GH_TOKEN=... mise run github:ci:secrets:sync --repo ricon-family/fold:c0da --pat --yes" header="Sync only C0DA_GITHUB_PAT to fold with explicit GitHub auth"
set -euo pipefail

ROOT="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"
# shellcheck source=.mise/lib/github/ci.sh
source "$ROOT/.mise/lib/github/ci.sh"

REPO_TARGETS="${usage_repo:-}"
PAT_ONLY="${usage_pat:-false}"
YES="${usage_yes:-false}"
TMP_DIR=$(mktemp -d)
TARGETS_FILE="$TMP_DIR/targets.tsv"
status=0

cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT

github_ci_require_tools
github_ci_targets_file "$REPO_TARGETS" "$TARGETS_FILE"

if [ "$YES" = "true" ]; then
  printf 'Mode\tmutating\n'
  printf 'Effect\tsets selected per-agent GitHub Actions secrets on target repos\n'
else
  printf 'Mode\tdry-run\n'
  printf 'Effect\tno GitHub Actions secrets changed; pass --yes to sync\n'
fi
if [ "$PAT_ONLY" = "true" ]; then
  SECRET_SET="pat"
  printf 'Scope\t%s\n' 'agent GitHub PAT only; no GPG, email, B2, or PI secrets'
else
  SECRET_SET="required"
  printf 'Scope\t%s\n' 'agent GitHub PAT, GPG private key, and email password only; run github:ci:pi-auth:sync separately for PI_AUTH_JSON'
fi
printf 'Auth\t%s\n' 'uses ambient gh auth / GH_TOKEN for GitHub writes; no agent PAT is used as writer implicitly'
printf 'Rotation\t%s\n' 'no PATs are created, rotated, or revoked; existing secret-provider values are uploaded'
printf '\n'

github_ci_sync_agent_secrets "$TARGETS_FILE" "$YES" "$TMP_DIR" "$SECRET_SET" || status=1
exit "$status"
