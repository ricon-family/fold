#!/usr/bin/env bash
#MISE description="Roll out a shiv package pin across fresh repo clones"
#USAGE flag "-y --yes" default=#false help="Commit and push rollout branches"
#USAGE flag "--plan <path>" default="" help="TSV rows: repo<TAB>push-agent; push-agent '-' uses ambient GitHub auth"
#USAGE flag "--branch <branch>" default="" help="Rollout branch name (default: <operator>/<package>-<version>)"
#USAGE flag "--base <branch>" default="main" help="Base branch to clone"
#USAGE flag "--message <message>" default="" help="Commit message (default: deps: bump <package> to <version>)"
#USAGE flag "--work-dir <path>" default="" help="Directory for fresh clones (default: temporary directory)"
#USAGE flag "--add-missing" default=#false help="Add the shiv dependency when it is absent from mise.toml"
#USAGE flag "--no-gpg-sign" default=#false help="Do not GPG-sign commits (intended for tests or emergency recovery)"
#USAGE arg "<package>" help="Shiv package name, with or without shiv: prefix"
#USAGE arg "<version>" help="Target version/pin, usually a minor stream like 0.6"
#USAGE example "mise run shiv:rollout emails 0.6 --plan /tmp/emails.tsv --add-missing" header="Dry-run an emails rollout"
#USAGE example "mise run shiv:rollout emails 0.6 --plan /tmp/emails.tsv --add-missing --yes" header="Commit and push rollout branches"
set -euo pipefail

ROOT="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"
YES="${usage_yes:-false}"
PLAN_FILE="${usage_plan:-}"
BASE_BRANCH="${usage_base:-main}"
PACKAGE_RAW="${usage_package:?package required}"
TARGET_VERSION="${usage_version:?version required}"
BRANCH_NAME="${usage_branch:-}"
COMMIT_MESSAGE="${usage_message:-}"
WORK_DIR="${usage_work_dir:-}"
ADD_MISSING="${usage_add_missing:-false}"
NO_GPG_SIGN="${usage_no_gpg_sign:-false}"
GIT_BIN="${GIT:-git}"
SECRETS_BIN="${SECRETS:-secrets}"

require_tool() {
  local tool
  for tool in "$@"; do
    if ! command -v "$tool" >/dev/null 2>&1; then
      echo "ERROR: required tool not found: $tool" >&2
      exit 1
    fi
  done
}

validate_repo() {
  local repo="$1"
  if [[ ! "$repo" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]]; then
    echo "ERROR: repo must be OWNER/REPO: $repo" >&2
    exit 1
  fi
}

validate_agent_or_dash() {
  local agent="$1"
  [ "$agent" = "-" ] && return 0
  if [[ ! "$agent" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "ERROR: invalid push agent: $agent" >&2
    exit 1
  fi
}

normalize_package() {
  local package="$1"
  package="${package#shiv:}"
  if [[ ! "$package" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "ERROR: invalid shiv package: $package" >&2
    exit 1
  fi
  printf '%s\n' "$package"
}

slugify_version() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '-'
}

get_push_token() {
  local agent="$1"
  local token
  [ "$agent" = "-" ] && return 0

  if ! token=$("$SECRETS_BIN" get "$agent/github-pat" 2>/dev/null); then
    echo "ERROR: could not read $agent/github-pat" >&2
    exit 1
  fi
  if [ -z "$token" ]; then
    echo "ERROR: $agent/github-pat is empty" >&2
    exit 1
  fi
  printf '%s\n' "$token"
}

run_git() {
  local token="$1"
  shift

  if [ -n "$token" ]; then
    GH_TOKEN="$token" GIT_TERMINAL_PROMPT=0 "$GIT_BIN" \
      -c credential.helper= \
      -c "credential.helper=!f() { echo username=x-access-token; echo \"password=\$GH_TOKEN\"; }; f" \
      "$@"
  else
    GIT_TERMINAL_PROMPT=0 "$GIT_BIN" "$@"
  fi
}

update_mise_toml() {
  local repo_dir="$1" status_file tmp_file status
  local mise_file="$repo_dir/mise.toml"

  if [ ! -f "$mise_file" ]; then
    echo "missing-mise"
    return 0
  fi

  status_file=$(mktemp)
  tmp_file=$(mktemp)

  awk \
    -v package="$PACKAGE" \
    -v target_version="$TARGET_VERSION" \
    -v add_missing="$ADD_MISSING" \
    -v status_file="$status_file" '
      { lines[NR] = $0 }

      END {
        key = "shiv:" package
        wanted_line = "\"" key "\" = \"" target_version "\""
        tools_start = 0
        tools_end = 0
        found = 0
        changed = 0

        for (i = 1; i <= NR; i++) {
          if (lines[i] ~ /^\[tools\][[:space:]]*$/) {
            tools_start = i
            tools_end = NR
            for (j = i + 1; j <= NR; j++) {
              if (lines[j] ~ /^\[/) {
                tools_end = j - 1
                break
              }
            }
            break
          }
        }

        if (!tools_start) {
          print "missing-tools" > status_file
          for (i = 1; i <= NR; i++) print lines[i]
          exit 0
        }

        key_re = "^[[:space:]]*\\\"" key "\\\"[[:space:]]*="
        for (i = tools_start + 1; i <= tools_end; i++) {
          if (lines[i] ~ key_re) {
            found = 1
            old = lines[i]
            sub(/= *"[^"]*"/, "= \"" target_version "\"", lines[i])
            if (lines[i] != old) changed = 1
          }
        }

        insert_after = tools_start
        for (i = tools_start + 1; i <= tools_end; i++) {
          if (lines[i] ~ /^[[:space:]]*"shiv:/) insert_after = i
        }

        if (!found && add_missing == "true") changed = 1

        for (i = 1; i <= NR; i++) {
          print lines[i]
          if (!found && add_missing == "true" && i == insert_after) {
            print wanted_line
          }
        }

        if (!found && add_missing != "true") print "missing" > status_file
        else if (changed) print (found ? "updated" : "added") > status_file
        else print "unchanged" > status_file
      }
    ' "$mise_file" > "$tmp_file"

  status=$(cat "$status_file")
  if [ "$status" = "updated" ] || [ "$status" = "added" ]; then
    mv "$tmp_file" "$mise_file"
  else
    rm -f "$tmp_file"
  fi
  rm -f "$status_file"

  echo "$status"
}

configure_operator_identity() {
  local repo_dir="$1"

  run_git "" -C "$repo_dir" config user.name "$OPERATOR_NAME"
  run_git "" -C "$repo_dir" config user.email "$OPERATOR_EMAIL"
  if [ -n "$OPERATOR_SIGNING_KEY" ]; then
    run_git "" -C "$repo_dir" config user.signingkey "$OPERATOR_SIGNING_KEY"
  fi
  if [ "$NO_GPG_SIGN" = "true" ]; then
    run_git "" -C "$repo_dir" config commit.gpgsign false
  else
    run_git "" -C "$repo_dir" config commit.gpgsign true
  fi
}

process_repo() {
  local repo="$1" push_agent="$2"
  local token clone_dir status

  validate_repo "$repo"
  validate_agent_or_dash "$push_agent"
  token=$(get_push_token "$push_agent")

  clone_dir="$WORK_DIR/${repo//\//__}"
  rm -rf "$clone_dir"

  echo "repo: $repo"
  echo "  push actor: $push_agent"
  echo "  clone: $clone_dir"

  run_git "$token" clone --branch "$BASE_BRANCH" "https://github.com/$repo.git" "$clone_dir" >/dev/null
  configure_operator_identity "$clone_dir"

  status=$(update_mise_toml "$clone_dir")
  echo "  dependency: $status"

  case "$status" in
    updated|added)
      run_git "" -C "$clone_dir" diff -- mise.toml | sed 's/^/    /'
      ;;
    unchanged|missing)
      return 0
      ;;
    missing-mise|missing-tools)
      echo "  warning: $status" >&2
      return 0
      ;;
    *)
      echo "ERROR: unexpected dependency status for $repo: $status" >&2
      exit 1
      ;;
  esac

  if [ "$YES" != "true" ]; then
    echo "  dry-run: would commit and push $BRANCH_NAME"
    return 0
  fi

  run_git "" -C "$clone_dir" checkout -B "$BRANCH_NAME" >/dev/null
  run_git "" -C "$clone_dir" add mise.toml
  if [ "$NO_GPG_SIGN" = "true" ]; then
    run_git "" -C "$clone_dir" commit --no-gpg-sign -m "$COMMIT_MESSAGE" >/dev/null
  else
    run_git "" -C "$clone_dir" commit -m "$COMMIT_MESSAGE" >/dev/null
  fi
  run_git "$token" -C "$clone_dir" push origin "HEAD:refs/heads/$BRANCH_NAME" >/dev/null
  echo "  pushed: $BRANCH_NAME"
}

require_tool "$GIT_BIN" awk mktemp sed tr

PACKAGE=$(normalize_package "$PACKAGE_RAW")
PACKAGE_KEY="shiv:$PACKAGE"
VERSION_SLUG=$(slugify_version "$TARGET_VERSION")

if [ -z "$PLAN_FILE" ]; then
  echo "ERROR: --plan is required" >&2
  exit 1
fi
if [ ! -f "$PLAN_FILE" ]; then
  echo "ERROR: plan file not found: $PLAN_FILE" >&2
  exit 1
fi

if [ "$PLAN_FILE" != "-" ]; then
  PLAN_FILE=$(cd "$(dirname "$PLAN_FILE")" && pwd)/$(basename "$PLAN_FILE")
fi

if [ -z "$BRANCH_NAME" ]; then
  operator_slug=$(printf '%s' "${GIT_AUTHOR_NAME:-k7r2}" | tr -c 'A-Za-z0-9._-' '-')
  BRANCH_NAME="$operator_slug/$PACKAGE-$VERSION_SLUG"
fi
if [ -z "$COMMIT_MESSAGE" ]; then
  COMMIT_MESSAGE="deps: bump $PACKAGE to $TARGET_VERSION"
fi

OPERATOR_NAME="${GIT_AUTHOR_NAME:-$(git -C "$ROOT" config user.name)}"
OPERATOR_EMAIL="${GIT_AUTHOR_EMAIL:-$(git -C "$ROOT" config user.email)}"
OPERATOR_SIGNING_KEY=$(git -C "$ROOT" config user.signingkey || true)

if [ -z "$OPERATOR_NAME" ] || [ -z "$OPERATOR_EMAIL" ]; then
  echo "ERROR: could not determine operator git identity" >&2
  exit 1
fi

if grep -vE '^[[:space:]]*(#|$)' "$PLAN_FILE" | grep -Eqv $'^[^\t]+\t[^\t]+$'; then
  echo "ERROR: plan rows must be: repo<TAB>push-agent" >&2
  exit 1
fi

cleanup_work_dir=false
if [ -z "$WORK_DIR" ]; then
  WORK_DIR=$(mktemp -d "${TMPDIR:-/tmp}/shiv-rollout.XXXXXX")
  cleanup_work_dir=true
else
  mkdir -p "$WORK_DIR"
fi
if $cleanup_work_dir; then
  trap 'rm -rf "$WORK_DIR"' EXIT
fi

printf 'Shiv rollout\n\n'
printf 'package: %s\n' "$PACKAGE_KEY"
printf 'version: %s\n' "$TARGET_VERSION"
printf 'base:    %s\n' "$BASE_BRANCH"
printf 'branch:  %s\n' "$BRANCH_NAME"
printf 'commit:  %s\n' "$COMMIT_MESSAGE"
printf 'mode:    %s\n' "$( [ "$YES" = "true" ] && echo mutate || echo dry-run )"
printf 'missing: %s\n\n' "$( [ "$ADD_MISSING" = "true" ] && echo add || echo skip )"

while IFS=$'\t' read -r repo push_agent extra; do
  [ -z "${repo//[[:space:]]/}" ] && continue
  [[ "$repo" == \#* ]] && continue
  if [ -n "${extra:-}" ]; then
    echo "ERROR: too many fields in plan row for $repo" >&2
    exit 1
  fi
  process_repo "$repo" "$push_agent"
done < "$PLAN_FILE"
